{
  "permissions": {
    "allow": [
      "Bash(make up)",
      "Bash(make down)",
      "Bash(make shell)",
      "Bash(make test:*)",
      "Bash(make logs:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(php artisan test:*)",
      "Bash(php artisan route:list:*)",
      "Bash(php artisan migrate:status)",
      "Bash(php artisan about)",
      "Bash(composer install:*)",
      "Bash(composer dump-autoload:*)",
      "Bash(npm ci)",
      "Bash(npm run lint:*)",
      "Bash(npm run build)",
      "Bash(npx tsc:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-edited-file.sh\"",
            "description": "Checa sintaxe PHP de arquivos .php recém-editados"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"[Claude Code] Sessao encerrada em $(date +%H:%M:%S). Lembre de commitar suas mudancas.\"'",
            "description": "Lembrete de commit ao encerrar sessao"
          }
        ]
      }
    ]
  }
}
